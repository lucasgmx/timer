# Public Firebase browser config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_TIMER_USERNAME_EMAIL_DOMAIN=timer.local

# Server-side Firebase Admin config.
# Prefer GOOGLE_APPLICATION_CREDENTIALS on Cloud Run, or provide one of these locally:
FIREBASE_ADMIN_CREDENTIALS_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Username auth and app access/bootstrap
TIMER_ALLOWED_USERNAMES=lucas
TIMER_BOOTSTRAP_ADMIN_USERNAMES=lucas
TIMER_DEFAULT_CLIENT_NAME=Marques LLC
TIMER_TIME_ZONE=America/New_York

# Optional one-off account creation helper.
TIMER_CREATE_USERNAME=lucas
TIMER_CREATE_USER_PASSWORD=

# Google reCAPTCHA Enterprise (invisible captcha on login)
# 1. Enable reCAPTCHA Enterprise API: gcloud services enable recaptchaenterprise.googleapis.com --project=PROJECT_ID
# 2. Create site key: gcloud recaptcha keys create --display-name="Timer Login" --web --domains=yourdomain.com,localhost --integration-type=score --project=PROJECT_ID --format="value(name)"
# 3. Create server API key: gcloud services api-keys create --display-name="Timer reCAPTCHA Server" --api-target=service=recaptchaenterprise.googleapis.com --project=PROJECT_ID --format="value(keyString)"
# Leave blank to disable captcha (e.g. local development).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_API_KEY=
RECAPTCHA_PROJECT_ID=

# Passkeys (WebAuthn) — set to your deployed domain for production.
# Defaults to localhost / http://localhost:6001 for local development.
PASSKEY_RP_ID=timer.marques.llc
PASSKEY_ORIGIN=https://timer.marques.llc
